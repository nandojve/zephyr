/ {
	morse: morse {
		compatible = "zephyr,morse";

		speed = <20>;
		timer-unit = <&tc1>;

		rx: receiver {
			compatible = "zephyr,morse-gpio-rx";

			gpios = <&pioa 23 GPIO_ACTIVE_LOW>;
		};

		tx: transmitter {
			compatible = "zephyr,morse-gpio-tx";

			gpios = <&pioa 23 GPIO_ACTIVE_LOW>;
		};
	};
};

&tc1 {
	clk = <4>;
	status = "okay";
};
